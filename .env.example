# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# TURSO_DATABASE_URL: Turso database connection URL
# Local: "file:lunch_attendance.db"
# Online: "libsql://your-database.turso.io"
TURSO_DATABASE_URL="file:lunch_attendance.db"

# TURSO_AUTH_TOKEN: Turso authentication token (required for online DB)
TURSO_AUTH_TOKEN=""
