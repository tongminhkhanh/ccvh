# VITE_CLIPROXY_API: Endpoint for AI Client Proxy (e.g., http://localhost:3000/v1)
VITE_CLIPROXY_API="http://localhost:3000/v1"
# VITE_CLIPROXY_TOKEN: Token for AI Client Proxy
VITE_CLIPROXY_TOKEN="YOUR_TOKEN_HERE"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# TURSO_DATABASE_URL: Turso database connection URL
# Local: "file:lunch_attendance.db"
# Online: "libsql://your-database.turso.io"
TURSO_DATABASE_URL="file:lunch_attendance.db"

# TURSO_AUTH_TOKEN: Turso authentication token (required for online DB)
TURSO_AUTH_TOKEN=""
